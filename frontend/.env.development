# Used automatically when you run `npm run dev` (Vite development mode).
# Set VITE_DISABLE_AUTH=true to skip Auth0 locally (requires REQUIRE_AUTH=false on the API).
# Production builds use `npm run build` (mode production) and do NOT load this file.
#
# Match backend REQUIRE_AUTH=true — log in with Auth0 for API calls.
VITE_DISABLE_AUTH=true

# Use Vite proxy to backend (see vite.config.ts). Leave empty for same-origin /api → localhost:8000.
# VITE_API_BASE_URL=
