# Frontend env — copy to `.env.local` (or set in Vercel → Environment Variables).
# Vite loads from `frontend/.env*`.
# Do not put OPENAI_API_KEY or other secrets here — use the repo root `.env` (enhanced-server loads it first).
#
# ---------------------------------------------------------------------------
# Local dev (laptop / iMac) + API on another host (e.g. Mac mini on LAN)
# ---------------------------------------------------------------------------
# Do NOT set VITE_API_BASE_URL here. The SPA uses relative /api and /health; Vite proxies to FastAPI.
# Each machine: set VITE_DEV_API_PROXY_TARGET only in frontend/.env.local (gitignored), e.g.:
#   VITE_DEV_API_PROXY_TARGET=http://192.168.42.5:8000
# Mac mini keeps its own repo root `.env` (DATABASE_*, etc.); it does not need this file unless you run Vite there.
# If FastAPI runs on the same machine as Vite: omit or use http://127.0.0.1:8000 (default).
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8000
#
# CRM enhanced server (Node :3001): defaults to localhost. If it runs on another host:
# VITE_CRM_SERVER_URL=http://192.168.42.5:3001
#
# ---------------------------------------------------------------------------
# Production / deployed SPA (Vercel, etc.)
# ---------------------------------------------------------------------------
# Browser must call the public API directly (no Vite proxy). Set:
# VITE_API_BASE_URL=https://api.yourdomain.com

# VITE_API_BASE_URL=https://api.nivogroup.se

# CRM (Node enhanced server) — do NOT use VITE_API_BASE_URL for /crm calls.
# Leave VITE_CRM_BASE_URL unset: browser uses /crm → dev proxy or same-origin in prod.
# VITE_CRM_BASE_URL=
#
# Resend (CRM send) — enhanced-server reads this file and repo root .env. Copy to .env.local (gitignored):
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=outreach@your-verified-domain.com
# RESEND_REPLY_DOMAIN=send.yourdomain.com   # optional: defaults to domain of RESEND_FROM_EMAIL

# Set true to force no Auth0 (optional; .env.development already does this for `npm run dev`)
# VITE_DISABLE_AUTH=true

# Auth0 (same values in Vercel) — omit or use VITE_DISABLE_AUTH for local no-login
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-spa-client-id
VITE_AUTH0_AUDIENCE=https://api.nivogroup.se

# Optional: comma-separated emails that can see Admin (in addition to role from GET /api/me)
# VITE_ADMIN_EMAILS=admin@example.com,you@company.com

# Prefer ENRICHMENT_DEFAULT_SYNC_RUN on the API server. Optional: send syncRun from the SPA (still runs on the API).
# VITE_ENRICHMENT_SYNC_RUN=true

# Unified Nav v1 is the default product shell (segmented sidebar; phase-1 route aliases). See README.
# Set only to use the legacy sidebar:
# VITE_NAV_UNIFIED_V1=false
# VITE_HIDE_IN_DEVELOPMENT=false
# VITE_HIDE_LEGACY_SURFACES=false
