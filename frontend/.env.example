# Frontend env — copy to `.env.local` (or set in Vercel → Environment Variables).
# Vite loads from `frontend/.env*`.
#
# Real DB via API (typical for feature work)
# - The browser never talks to Postgres. Set VITE_API_BASE_URL to the deployed API (e.g.
#   https://api.nivogroup.se). All reads/writes go API → DB; you exercise the same backend as prod.
# - Auth: use real Auth0 values in .env.local when the API has REQUIRE_AUTH=true.
#
# Schema changes (migrations)
# - Add SQL under `database/migrations/` in git; deploy API code; run migrations on the host that
#   owns Postgres (see `scripts/run_postgres_migrations.sh`, `docs/DEPLOY_MAC_MINI.md`). Do not
#   point a local Postgres at prod from your laptop.
#
# Local dev without Auth0: `npm run dev` loads `.env.development` (VITE_DISABLE_AUTH). That only
# works if your local API has REQUIRE_AUTH=false. For real-API testing, use .env.local + Auth0.

# Backend API URL (production: tunnel URL)
VITE_API_BASE_URL=https://api.nivogroup.se
# Local dev: leave unset to use Vite proxy, or VITE_API_BASE_URL=http://127.0.0.1:8000

# Set true to force no Auth0 (optional; .env.development already does this for `npm run dev`)
# VITE_DISABLE_AUTH=true

# Auth0 (same values in Vercel) — omit or use VITE_DISABLE_AUTH for local no-login
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-spa-client-id
VITE_AUTH0_AUDIENCE=https://api.nivogroup.se

# Optional: comma-separated emails that can see Admin (in addition to role from GET /api/me)
# VITE_ADMIN_EMAILS=admin@example.com,you@company.com

# Prefer ENRICHMENT_DEFAULT_SYNC_RUN on the API server. Optional: send syncRun from the SPA (still runs on the API).
# VITE_ENRICHMENT_SYNC_RUN=true
