# =============================================================================
# Nivo — root environment template
# =============================================================================
# Copy to `.env` and replace placeholders. Never commit `.env` (gitignored).
#
#   cp .env.example .env
#
# Who reads this:
# - Python FastAPI (`backend/`), scripts, RQ workers — via `load_dotenv` / shell
# - Node enhanced server (`frontend/server/`) — loads project root `.env` then `frontend/.env.local`
#
# Frontend-only vars (VITE_*) usually live in `frontend/.env.local` — see `frontend/.env.example`.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# local = dev; prod = stricter defaults
APP_ENV=local
# FastAPI: require `Authorization: Bearer <jwt>` on /api routes
REQUIRE_AUTH=false
# If true, only users in `allowed_users` with enabled=true may access (after JWT)
REQUIRE_ALLOWLIST=false
# Optional: comma-separated email domains → auto analyst role on first login (see docs/BOOTSTRAP_ROLES.md)
# AUTO_APPROVE_EMAIL_DOMAINS=yourcompany.se

# -----------------------------------------------------------------------------
# Auth0 (backend JWT verification — set when REQUIRE_AUTH=true)
# -----------------------------------------------------------------------------
# AUTH0_DOMAIN=your-tenant.us.auth0.com
# AUTH0_AUDIENCE=https://api.yourdomain.com

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
DATABASE_SOURCE=postgres

# Option A — discrete vars (used by scripts and many services)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=nivo
POSTGRES_USER=nivo
POSTGRES_PASSWORD=change-me

# Option B — single URL (overrides discrete vars when supported)
# Remote example: VPN to Mac mini / Docker host
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5433/nivo

# Optional: pin GPT target universe to a screening run UUID (see `database/migrations` 044+046)
# GPT_TARGET_UNIVERSE_RUN_ID=00000000-0000-0000-0000-000000000000

# -----------------------------------------------------------------------------
# CRM email (Resend) — optional until you send or receive CRM mail
# -----------------------------------------------------------------------------
# Public URL of the app for tracking links in HTML mail (browser origin, not FastAPI)
# APP_BASE_URL=http://localhost:8080
#
# Resend — CRM outbound + inbound (see docs/CRM_SETUP.md, docs/email_inbound_resend.md)
# Minimum for send: RESEND_API_KEY + RESEND_FROM_EMAIL (verified domain). Reply-To domain defaults to From’s domain.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=outreach@updates.yourdomain.com
# RESEND_FROM=outreach@updates.yourdomain.com   # alias some tooling expects; often same as RESEND_FROM_EMAIL
# CRM_SENDER_FROM=info@crm.yourdomain.com
# RESEND_REPLY_DOMAIN=send.nivogroup.se   # optional if different from From domain; required for Python inbound webhook routing
# RESEND_WEBHOOK_SECRET=whsec_...   # Resend Dashboard → Webhooks → Signing secret (FastAPI /webhooks/email/inbound)
# RESEND_WEBHOOK_VERIFY_DISABLED=true   # local only; skip Svix verify if secret unset; never use in production
# Reply-To in sent mail: reply+<token>@RESEND_REPLY_DOMAIN

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-replace-me
OPENAI_MODEL=gpt-4o-mini

# Optional script / retrieval overrides (see comments in repo scripts)
# GPT_WEBSITE_RETRIEVAL_MODEL=gpt-4o
# GPT_CHAT_SEARCH_MODEL=gpt-4o-search-preview
# USE_OPENAI_AGENT_FOR_MARKET_ANALYSIS=true
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=local
# LLM_MODEL=local-model
# LLM_PROVIDER=openai_compat

# -----------------------------------------------------------------------------
# Redis (RQ: enrichment, deep research workers)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
# In Docker Compose API container use service hostname, not localhost:
# REDIS_URL=redis://redis:6379/0

# Optional: run enrichment inline in API instead of queue (dev only; long requests)
# ENRICHMENT_DEFAULT_SYNC_RUN=true

# -----------------------------------------------------------------------------
# Scraping (optional)
# -----------------------------------------------------------------------------
# PUPPETEER_SERVICE_URL=https://chrome.browserless.io/scrape
# PUPPETEER_SERVICE_TOKEN=replace-me

# -----------------------------------------------------------------------------
# Web search (Deep Research)
# -----------------------------------------------------------------------------
TAVILY_API_KEY=tvly-replace-me
# SERPAPI_KEY=
RETRIEVAL_PROVIDER=auto
# WEB_RETRIEVAL_SEARCH_PROVIDER=tavily

# -----------------------------------------------------------------------------
# Integrations (optional)
# -----------------------------------------------------------------------------
# COPPER_API_TOKEN=

# -----------------------------------------------------------------------------
# CORS (FastAPI — browser origins allowed to call the API)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,https://yourdomain.com
# CORS_ALLOW_VERCEL_PREVIEWS=false

# -----------------------------------------------------------------------------
# Misc (optional — set if your deploy expects them)
# -----------------------------------------------------------------------------
# WEBSITE_DOMAIN=yourdomain.com
# WEBSITE_NAME=Your App Name
# NODE_ENV=development

# ----------------------------------------------------------------------------
# Frontend (Vite) — set in frontend/.env or root .env; for Vercel set in Project → Environment Variables
# ----------------------------------------------------------------------------
# See frontend/.env.example. Dev on laptop: usually omit VITE_API_BASE_URL; set VITE_DEV_API_PROXY_TARGET
# in frontend/.env.local to your Mac mini FastAPI URL. Mac mini uses repo root .env for API/DB only.
# Production SPA: VITE_API_BASE_URL=https://api.yourdomain.com
# VITE_API_BASE_URL=https://api.nivogroup.se
# VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
# VITE_AUTH0_CLIENT_ID=your-spa-client-id
# VITE_AUTH0_AUDIENCE=https://api.yourdomain.com
# Optional scraper: VITE_SCRAPER_API_BASE_URL=http://localhost:3000
# VITE_SCRAPER_APP_BASE_URL=http://localhost:3000
# Vite dev proxy target for /crm → enhanced-server (default http://localhost:3001)
# VITE_CRM_SERVER_URL=http://localhost:3001
#
# Browser base for CRM API calls — must NOT be the FastAPI URL (VITE_API_BASE_URL).
# Leave unset in dev so requests use same-origin /crm (proxied). In prod, set if CRM is on another host.
# VITE_CRM_BASE_URL=https://your-enhanced-server.example.com
#
# Unified product navigation (Vite / frontend — see README "Unified Nav v1"; default is on)
# Legacy sidebar only:
# VITE_NAV_UNIFIED_V1=false
# Hide "In development" sidebar block (screening, deep research preview links)
# VITE_HIDE_IN_DEVELOPMENT=false
# Legacy nav only: hide Prospects + GPT target universe from sidebar
# VITE_HIDE_LEGACY_SURFACES=false
