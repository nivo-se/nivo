# ============================================================================
# Nivo Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values
# cp .env.example .env

# ----------------------------------------------------------------------------
# App Environment
# ----------------------------------------------------------------------------
# local = dev with optional auth; prod = require JWT for /api routes
APP_ENV=local
# DO NOT flip this to true for local mini/laptop dev unless you also enable Auth0 login in the SPA.
# If REQUIRE_AUTH=true while VITE_DISABLE_AUTH=true, Universe/Dashboard will 401 and show 0 rows.
# Prod/Auth0 testing only: set true intentionally and use real JWTs.
REQUIRE_AUTH=false
# When true, only subs in allowed_users with enabled=true can access (after JWT)
REQUIRE_ALLOWLIST=false

# Comma-separated email domains: on login, users with no role yet get one automatically.
# If user_roles is empty, first matching user becomes admin; everyone else from these domains becomes analyst.
# Also adds them to allowed_users when REQUIRE_ALLOWLIST=true. Example: nivogroup.se
# Leave unset to require "Claim first admin" or manual inserts (see docs/BOOTSTRAP_ROLES.md).
# AUTO_APPROVE_EMAIL_DOMAINS=nivogroup.se

# ----------------------------------------------------------------------------
# Auth0 (user auth – leave unset for local dev = no login)
# ----------------------------------------------------------------------------
# Backend (when REQUIRE_AUTH=true): verifies JWTs via JWKS.
# AUTH0_DOMAIN=your-tenant.auth0.com
# AUTH0_AUDIENCE=https://api.yourdomain.com
# Frontend: set for production login (see Frontend section below).
# VITE_AUTH0_DOMAIN=your-tenant.auth0.com
# VITE_AUTH0_CLIENT_ID=your-spa-client-id
# VITE_AUTH0_AUDIENCE=https://api.yourdomain.com

# ----------------------------------------------------------------------------
# Database (Postgres only)
# ----------------------------------------------------------------------------
DATABASE_SOURCE=postgres

# Local Postgres (when DATABASE_SOURCE=postgres)
# Local dev: docker-compose.postgres.yml → POSTGRES_HOST=localhost, POSTGRES_PORT=5433
# Mac mini: docker-compose.yml → host=postgres, port=5432
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=nivo
POSTGRES_USER=nivo
POSTGRES_PASSWORD=nivo

# Optional fixed cohort for /gpt-target-universe: UUID of a row in public.screening_runs.
# If unset, the API uses the newest screening run that has rows in screening_website_research_companies.
# You can also pass ?run_id=<uuid> or pick a run in the UI. Env still wins over auto when set (unless overridden by ?run_id).
# Requires migrations 044_screening_runs + 046_screening_website_research_companies (see ./scripts/run_postgres_migrations.sh).
# GPT_TARGET_UNIVERSE_RUN_ID=dd15199e-e342-4977-b639-9be1d72acb56

# ----------------------------------------------------------------------------
# CRM (uses same Postgres as backend – no Supabase required)
# ----------------------------------------------------------------------------
# CRM uses schema "deep_research". Run migrations 024 + 026 so tables exist:
# companies, company_profiles, deals, contacts, emails, interactions, etc.
# Uses POSTGRES_* vars above. For custom DB: DATABASE_URL=postgresql://user:pass@host:port/db

# ----------------------------------------------------------------------------
# Origination CRM (send + tracking) – optional; needed for /crm/emails/send
# ----------------------------------------------------------------------------
# Public origin of the Node CRM server (open/click tracking in HTML parts). In production set to your CRM host, e.g.:
# APP_BASE_URL=https://crm.nivogroup.se
# APP_BASE_URL=http://localhost:3001
#
# Resend — CRM outbound + inbound (see docs/CRM_SETUP.md, docs/email_inbound_resend.md)
# Minimum for send: RESEND_API_KEY + RESEND_FROM_EMAIL (verified domain). Reply-To domain defaults to From’s domain.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=outreach@updates.yourdomain.com
# RESEND_FROM=outreach@updates.yourdomain.com   # alias some tooling expects; often same as RESEND_FROM_EMAIL
# CRM_SENDER_FROM=info@crm.yourdomain.com
# RESEND_REPLY_DOMAIN=send.nivogroup.se   # optional if different from From domain; required for Python inbound webhook routing
# RESEND_WEBHOOK_SECRET=whsec_...   # Resend Dashboard → Webhooks → Signing secret (FastAPI /webhooks/email/inbound)
# RESEND_WEBHOOK_VERIFY_DISABLED=true   # local only; skip Svix verify if secret unset; never use in production
# Reply-To in sent mail: reply+<token>@RESEND_REPLY_DOMAIN

# Gmail — send from your own inbox (optional; see docs/CRM_GMAIL_OAUTH.md)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/crm/gmail/oauth/callback
# Production (Node on crm.nivogroup.se): https://crm.nivogroup.se/crm/gmail/oauth/callback — must match Google OAuth client "Authorized redirect URIs"
# GMAIL_OAUTH_ENCRYPTION_KEY=   # openssl rand -base64 32
# CRM_GMAIL_OAUTH_SUCCESS_URL=http://localhost:8080

# ----------------------------------------------------------------------------
# OpenAI / LLM Configuration
# ----------------------------------------------------------------------------
# Sourcing assistant (Universe "Sourcing chat" panel) calls OpenAI Chat Completions
# and turns your message into financial filters. Requires a key unless you use a local server.
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
# Optional alias (same as OPENAI_* for the sourcing assistant)
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini
# If set, uses OpenAI-compatible API (e.g. LM Studio). Dummy LLM_API_KEY is fine for many locals.
# LLM_BASE_URL=http://localhost:1234/v1
# If your local server errors on response_format, disable strict JSON mode:
# LLM_RESPONSE_JSON_OBJECT=false

# Sourcing assistant + analysis chat load versioned mandate from backend/config/nivo_context.json.
# Optional: absolute path to alternate JSON (must include version + summary_for_llm).
# NIVO_CONTEXT_PATH=

# Optional: model for scripts/gpt_batch_website_retrieval_test.py (Responses API + web_search).
# If unset, that script defaults to gpt-5.4-nano; override per run with --model.
# For higher URL recall (slower/costlier), use gpt-4o or another capable Responses model.
# Use any Responses-compatible model your key supports (see OpenAI model docs).
# GPT_WEBSITE_RETRIEVAL_MODEL=gpt-5.4-nano
# GPT_WEBSITE_RETRIEVAL_MODEL=gpt-4o
# Chat Completions search-preview models (built-in search) — use script flag --chat-search; many keys get 404 on Responses for these ids:
# GPT_CHAT_SEARCH_MODEL=gpt-4o-search-preview
# Disable Swedish user_location bias on web_search (default: enabled in that script):
# GPT_WEBSITE_RETRIEVAL_NO_USER_LOCATION=1

# Pilot: use OpenAI Agents SDK for market_analysis (default false)
# USE_OPENAI_AGENT_FOR_MARKET_ANALYSIS=true

# LLM Provider (for LMStudio transplant): set LLM_BASE_URL to use local model
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=your-model-name
# LLM_PROVIDER=openai_compat

# ----------------------------------------------------------------------------
# Redis Configuration (for background job queues: RQ enrichment, Deep Research)
# ----------------------------------------------------------------------------
# Local API on your machine (uvicorn): use host Redis — default below is fine if Redis listens on 6379.
REDIS_URL=redis://localhost:6379/0
# Docker Compose API (docker compose up): compose sets REDIS_URL=redis://redis:6379/0 for the api service
# (do not rely on localhost inside the container — it is not the host).

# Screening enrichment (set on the API process / backend server only — never in the browser):
# run the job inside that API process instead of Redis/RQ. Use when jobs stay queued and the UI shows
# “Enrichment in progress” with 0 rows saved. Large batches may hold the HTTP request open.
# ENRICHMENT_DEFAULT_SYNC_RUN=true

# ----------------------------------------------------------------------------
# Web Scraping & Enrichment
# ----------------------------------------------------------------------------
# Puppeteer Service (optional - for deep scraping of dynamic sites)
# Option 1: Use Browserless.io (recommended for production)
# PUPPETEER_SERVICE_URL=https://chrome.browserless.io/scrape
# PUPPETEER_SERVICE_TOKEN=your-browserless-token

# Option 2: Use your own Puppeteer worker (e.g. on Mac Mini or self-hosted)
# PUPPETEER_SERVICE_URL=https://your-puppeteer-service.example.com/scrape
# PUPPETEER_SERVICE_TOKEN=your-api-token-if-needed

# ----------------------------------------------------------------------------
# Deep Research — Web Search Providers
# ----------------------------------------------------------------------------
# Tavily: recommended for deep research retrieval (high-quality search results)
TAVILY_API_KEY=tvly-your-tavily-api-key-here
# SerpAPI: alternative search provider (Google results)
# SERPAPI_KEY=your-serpapi-key-here
# Web retrieval search provider: tavily (default) or openai (A/B test vs OpenAI web search)
# WEB_RETRIEVAL_SEARCH_PROVIDER=tavily
# Provider preference: "auto" (Tavily first), "tavily", "serpapi"
RETRIEVAL_PROVIDER=auto

# ----------------------------------------------------------------------------
# CRM Export
# ----------------------------------------------------------------------------
COPPER_API_TOKEN=your-copper-api-token-here

# ----------------------------------------------------------------------------
# Attio (CRM source of truth — one-way push from Nivo backend)
# ----------------------------------------------------------------------------
# Architecture: Nivo backend pushes enriched companies/contacts/research notes
# into Attio. Humans (and Claude via Attio's MCP server) edit Attio directly;
# Nivo never reads back. See docs/attio_integration.md (todo) for details.
#
# Generate the API key at https://app.attio.com → Settings → Developers → API
# key. Required scopes: object_configuration:read, record:read, record:write,
# note:read, note:write.
#
# ATTIO_SYNC_ENABLED defaults to false; the push module is a hard no-op until
# you flip it to "true". This makes it safe to deploy the code before the
# workspace is provisioned.
# ATTIO_SYNC_ENABLED=false
# ATTIO_API_KEY=
#
# Optional (Phase 1B — slug of the custom unique attribute on Companies that
# stores the Nivo company UUID; created by scripts/attio_setup_workspace.py):
# ATTIO_NIVO_COMPANY_ID_ATTR=nivo_company_id

# ----------------------------------------------------------------------------
# CORS Configuration (backend: allow these origins to call the API)
# ----------------------------------------------------------------------------
# Local dev + production frontend. Add every origin that will call the API.
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,https://nivogroup.se,https://app.nivogroup.se
# If using Vercel: add your app URL and optionally enable previews
# CORS_ORIGINS=http://localhost:5173,https://app.nivogroup.se,https://nivo-xxx.vercel.app
# CORS_ALLOW_VERCEL_PREVIEWS=true
# Opt-in: allow any *.vercel.app subdomain (set to true/1/yes when needed)
# CORS_ALLOW_VERCEL_PREVIEWS=false

# -----------------------------------------------------------------------------
# Misc (optional — set if your deploy expects them)
# -----------------------------------------------------------------------------
# WEBSITE_DOMAIN=yourdomain.com
# WEBSITE_NAME=Your App Name
# NODE_ENV=development
# ----------------------------------------------------------------------------
# Frontend (Vite) — set in frontend/.env or root .env; for Vercel set in Project → Environment Variables
# ----------------------------------------------------------------------------
# See frontend/.env.example. Dev on laptop: usually omit VITE_API_BASE_URL; set VITE_DEV_API_PROXY_TARGET
# in frontend/.env.local to your Mac mini FastAPI URL. Mac mini uses repo root .env for API/DB only.
# Production SPA: VITE_API_BASE_URL=https://api.yourdomain.com
# VITE_API_BASE_URL=https://api.nivogroup.se
# VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
# VITE_AUTH0_CLIENT_ID=your-spa-client-id
# VITE_AUTH0_AUDIENCE=https://api.yourdomain.com
# Optional scraper: VITE_SCRAPER_API_BASE_URL=http://localhost:3000
# VITE_SCRAPER_APP_BASE_URL=http://localhost:3000
# Vite dev proxy target for /crm → enhanced-server (default http://localhost:3001)
# VITE_CRM_SERVER_URL=http://localhost:3001
#
# Browser base for CRM API calls — must NOT be the FastAPI URL (VITE_API_BASE_URL).
# Leave unset in dev so requests use same-origin /crm (proxied). In prod, set if CRM is on another host.
# VITE_CRM_BASE_URL=https://your-enhanced-server.example.com
#
# Unified product navigation (Vite / frontend — see README "Unified Nav v1"; default is on)
# Legacy sidebar only:
# VITE_NAV_UNIFIED_V1=false
# Hide "In development" sidebar block (screening, deep research preview links)
# VITE_HIDE_IN_DEVELOPMENT=false
# Legacy nav only: hide Prospects + GPT target universe from sidebar
# VITE_HIDE_LEGACY_SURFACES=false

ATTIO_API_KEY=your-attio-api-key-here
