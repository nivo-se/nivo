# Copy to .env.cloudflare.local (gitignored) and fill in. Then from repo root:
#   ./scripts/apply_crm_cloudflare_ingress.sh
#
# Token: Cloudflare Dashboard → My Profile → API Tokens → Create with
#   Account → Cloudflare Tunnel → Edit (or use a custom token with that scope on the right account).
#
# Account ID: Cloudflare dashboard → any domain or Account home → copy "Account ID" from the right sidebar.
#
# Tunnel ID: Zero Trust → Networks → Tunnels → open the tunnel for api.nivogroup.se → copy UUID.
# Or run:   ./scripts/list_cloudflare_tunnels.sh   (needs TOKEN + ACCOUNT only)

CLOUDFLARE_API_TOKEN=
CF_ACCOUNT_ID=
CF_TUNNEL_ID=

# Optional overrides (defaults match production miniserver):
# CF_CRM_HOSTNAME=api.nivogroup.se
# CF_CRM_NODE_SERVICE=http://127.0.0.1:3001
